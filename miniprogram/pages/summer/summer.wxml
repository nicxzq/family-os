<view class="wrap">

  <!-- 日历视图：进来先看整个周期 -->
  <block wx:if="{{view === 'cal'}}">
    <view class="banner">
      <view class="banner-body">
        <view class="banner-date">{{title}}</view>
        <view class="banner-sub">{{rangeText}} · 点某一天看当天打卡</view>
      </view>
      <view class="banner-pct">
        <view class="banner-pct-num">{{calFull}}</view>
        <view class="banner-pct-label">全勤天 · 打卡 {{calDone}} 天</view>
      </view>
      <view class="banner-set" bindtap="openSet">⚙️</view>
    </view>

    <view class="cal card">
      <view class="cal-head">
        <view wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="cal-hd">{{item}}</view>
      </view>
      <view wx:for="{{weeks}}" wx:for-item="week" wx:key="index" class="cal-row">
        <view
          wx:for="{{week}}"
          wx:key="index"
          class="cal-cell {{item ? 'cal-cell--' + item.state : ''}} {{item.isToday ? 'is-today' : ''}}"
          bindtap="openDay"
          data-d="{{item.d}}"
        >
          <view wx:if="{{item}}" class="cal-month">{{item.month}}</view>
          <view wx:if="{{item}}" class="cal-num">{{item.num}}</view>
        </view>
      </view>
      <view class="cal-legend">
        <view class="cal-leg"><view class="cal-dot cal-dot--full"></view>全勤</view>
        <view class="cal-leg"><view class="cal-dot cal-dot--part"></view>打卡了一部分</view>
        <view class="cal-leg"><view class="cal-dot cal-dot--none"></view>还没打卡</view>
      </view>
    </view>
  </block>

  <!-- 单日视图 -->
  <block wx:if="{{view === 'day'}}">
    <view class="back-cal" bindtap="backCal">← 返回日历</view>

    <view class="banner">
      <view class="banner-body">
        <view class="banner-date">{{selCn}}</view>
        <view class="banner-sub">{{title}} · {{rangeText}}</view>
        <view class="banner-badge" wx:if="{{isToday}}">今天</view>
      </view>
      <view class="banner-pct">
        <view class="banner-pct-num">{{pct}}%</view>
        <view class="banner-pct-label">必做 {{doneReq}}/{{totalReq}}</view>
      </view>
    </view>

    <view class="motto">💬 {{motto}}</view>

    <block wx:for="{{slots}}" wx:for-item="slot" wx:for-index="si" wx:key="key">
      <view class="slot-title">{{slot.label}}</view>
      <view
        wx:for="{{slot.tasks}}"
        wx:for-item="task"
        wx:for-index="ti"
        wx:key="id"
        class="task {{task.done ? 'is-done' : ''}} {{task.req ? '' : 'is-opt'}}"
        bindtap="toggle"
        bindlongpress="longpress"
        data-s="{{si}}"
        data-t="{{ti}}"
      >
        <view class="task-box">{{task.done ? '✓' : ''}}</view>
        <view class="task-body">
          <view class="task-name">{{task.name}}</view>
          <view wx:if="{{task.time}}" class="task-time">{{task.time}}</view>
        </view>
        <view wx:if="{{!task.req}}" class="task-opt-tag">自选</view>
      </view>
    </block>

    <view class="day-hint">长按任意一项可以改名称、改时间或从计划中删掉。</view>

    <view class="day-nav">
      <button class="day-btn" bindtap="prev" disabled="{{atStart}}">← 前一天</button>
      <button class="day-btn day-btn--today" bindtap="today">回到今天</button>
      <button class="day-btn" bindtap="next" disabled="{{atEnd}}">后一天 →</button>
    </view>
  </block>

  <!-- 设置视图 -->
  <block wx:if="{{view === 'set'}}">
    <view class="back-cal" bindtap="backFromSet">← 返回日历</view>

    <view class="card set-card">
      <view class="set-title">打卡设置</view>
      <view class="set-row">
        <text class="set-label">标题</text>
        <input class="set-input" value="{{title}}" bindblur="onTitle" placeholder="给这份打卡起个名字" />
      </view>
      <view class="set-row">
        <text class="set-label">开始</text>
        <picker mode="date" value="{{cfg.start}}" bindchange="onStart">
          <view class="set-value">{{cfg.start}}</view>
        </picker>
      </view>
      <view class="set-row">
        <text class="set-label">结束</text>
        <picker mode="date" value="{{cfg.end}}" bindchange="onEnd">
          <view class="set-value">{{cfg.end}}</view>
        </picker>
      </view>
    </view>

    <view class="card set-card">
      <view class="set-title">每天的项目</view>
      <view class="set-hint">点名称或时间可以改；重复规则（每周几、指定日期）目前跟随初始计划。</view>

      <view wx:for="{{setItems}}" wx:key="id" class="set-item">
        <view class="set-item-main">
          <view class="set-item-name" bindtap="onSetName" data-id="{{item.id}}" data-name="{{item.name}}">{{item.name}}</view>
          <view class="set-item-meta">
            <text class="set-item-time" bindtap="onSetTime" data-id="{{item.id}}" data-time="{{item.time}}">{{item.time || '＋ 加时间'}}</text>
            <text class="set-item-rule">{{item.rule}}</text>
          </view>
          <picker range="{{slotOptions}}" value="{{item.slotIndex}}" bindchange="onSetSlot" data-id="{{item.id}}">
            <view class="set-item-slot">{{item.slotLabel}}</view>
          </picker>
        </view>
        <view class="set-item-side">
          <switch class="set-switch" checked="{{item.req}}" bindchange="onSetReq" data-id="{{item.id}}" color="#6FA86D" />
          <text class="set-switch-label">{{item.req ? '必做' : '自选'}}</text>
          <view class="set-item-del" bindtap="onSetDelete" data-id="{{item.id}}">删除</view>
        </view>
      </view>

      <view class="set-actions">
        <button class="set-btn" bindtap="addItem">＋ 新增项目</button>
        <button class="set-btn" bindtap="addSlot">＋ 新增时间段</button>
        <button class="set-btn set-btn--ghost" bindtap="resetCfg">恢复默认</button>
      </view>
    </view>
  </block>

  <view class="summer-note">打卡只记在这台手机上;完整版(日历、周回顾、AI 点评)在网站 /summer2026。</view>

</view>

<!-- 撒花 -->
<view wx:if="{{confetti.length}}" class="fx">
  <view
    wx:for="{{confetti}}"
    wx:key="id"
    class="fx-piece fx-piece--{{item.color}}"
    style="left:{{item.left}}%;animation-delay:{{item.delay}}ms;--fx-drift:{{item.drift}}rpx;--fx-spin:{{item.spin}}deg"
  ></view>
</view>

<fo-tabbar active="toolbox" />
