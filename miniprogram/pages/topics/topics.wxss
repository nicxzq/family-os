.featured-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.pill--now {
  background: var(--yellow-soft);
  color: var(--ink-soft);
}

.pill--coral { background: var(--coral-soft); color: var(--ink-soft); }
.pill--yellow { background: var(--yellow-soft); color: var(--ink-soft); }
.pill--green { background: var(--green-soft); color: var(--ink-soft); }
.pill--blue { background: var(--blue-soft); color: var(--ink-soft); }

.featured-q {
  font-size: var(--font-lg);
  font-weight: 700;
  line-height: 1.55;
  margin-bottom: var(--space-md);
}

.prompts {
  background: var(--cream-deep);
  border-radius: var(--radius-sm);
  padding: var(--space-md);
}

.prompts-label {
  font-size: var(--font-xs);
  letter-spacing: 0.14em;
  color: var(--ink-mute);
  margin-bottom: var(--space-sm);
}

.prompt-li {
  color: var(--ink-soft);
  font-size: var(--font-sm);
  margin-bottom: var(--space-xs);
}

.feat-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-md);
  gap: var(--space-sm);
}

.feat-btn {
  background: var(--cream-deep);
  color: var(--ink-soft);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  padding: var(--space-xs) var(--space-md);
  margin: 0;
  line-height: 1.6;
}

.feat-btn[disabled] {
  opacity: 0.35;
  background: var(--cream-deep);
  color: var(--ink-mute);
}

.week-counter {
  color: var(--ink-mute);
  font-size: var(--font-sm);
}

.all-section {
  margin-top: var(--space-lg);
}

.all-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--ink-soft);
  margin-bottom: var(--space-md);
}

.theme-block {
  margin-bottom: var(--space-md);
}

.theme-label {
  font-size: var(--font-xs);
  letter-spacing: 0.14em;
  color: var(--ink-mute);
  margin-bottom: var(--space-xs);
}

.topic-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.topic-chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--paper);
  border: 3rpx solid transparent;
  border-radius: var(--radius-full);
  padding: var(--space-xs) var(--space-sm);
  font-size: var(--font-xs);
  color: var(--ink-soft);
  box-shadow: var(--shadow-soft);
}

.topic-chip.is-active {
  border-color: var(--coral);
  background: var(--coral-soft);
  color: var(--ink);
}

.chip-num {
  font-size: var(--font-xs);
  color: var(--ink-mute);
}
