.kicker {
  display: inline-flex;
  font-size: var(--font-xs);
  color: var(--coral);
  background: var(--coral-soft);
  border-radius: var(--radius-full);
  padding: var(--space-xs) var(--space-sm);
  margin-bottom: var(--space-sm);
}

.r-title {
  font-size: var(--font-xxl);
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: var(--space-sm);
}

.hook {
  font-size: var(--font-md);
  color: var(--ink-soft);
  margin-bottom: var(--space-lg);
  white-space: pre-line;
}

.sec-h3 {
  font-size: var(--font-lg);
  font-weight: 700;
  margin-bottom: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.step-no {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--radius-full);
  background: var(--coral);
  color: var(--paper);
  font-size: var(--font-sm);
  flex-shrink: 0;
}

.sec-p {
  font-size: var(--font-sm);
  margin-bottom: var(--space-sm);
}

.sec-art {
  width: 100%;
  border-radius: var(--radius-sm);
  background: var(--paper);
  margin-top: var(--space-xs);
}

.sec-caption {
  font-size: var(--font-xs);
  color: var(--ink-mute);
  text-align: center;
  margin-top: var(--space-xs);
}

.quote {
  text-align: center;
  padding: var(--space-lg) var(--space-md);
}

.quote-text {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--coral);
  line-height: 1.5;
}

.quote-src {
  margin-top: var(--space-sm);
  font-size: var(--font-xs);
  color: var(--ink-mute);
}

.reflect-item {
  padding: var(--space-sm) 0;
  border-bottom: 2rpx dashed var(--cream-deep);
}

.reflect-q {
  font-size: var(--font-sm);
  color: var(--ink);
}

.reflect-hint {
  font-size: var(--font-xs);
  color: var(--ink-soft);
  padding: var(--space-xs) 0 0 var(--space-md);
}

.action {
  border: 4rpx solid var(--coral);
  background: var(--coral-soft);
}

.action-btn {
  margin-top: var(--space-sm);
  width: 60%;
}

.action-btn--done {
  background: var(--green);
}

/* 上一篇/下一篇 */
.piece-nav {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.piece-nav-item {
  flex: 1;
  margin-bottom: 0;
}

.piece-nav-item--next {
  text-align: right;
}

.piece-nav-dir {
  font-size: var(--font-sm);
  color: var(--coral);
  font-weight: 500;
  margin-bottom: var(--space-xs);
}

.piece-nav-title {
  font-size: var(--font-sm);
  color: var(--ink-soft);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
