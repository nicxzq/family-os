.piggy-card {
  text-align: center;
}

.piggy-emoji {
  font-size: 120rpx;
  line-height: 1.2;
}

.balance {
  font-size: var(--font-xxl);
  font-weight: 700;
  margin: var(--space-sm) 0;
}

.fill-bar {
  height: 20rpx;
  border-radius: var(--radius-full);
  background: var(--cream-deep);
  overflow: hidden;
}

.fill {
  height: 100%;
  border-radius: var(--radius-full);
  background: var(--yellow);
}

.fill-hint {
  font-size: var(--font-xs);
  color: var(--ink-mute);
  margin-top: var(--space-xs);
}

.quick-actions {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.action-btn {
  flex: 1;
  border-radius: var(--radius-full);
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--paper);
}

.action-btn--income {
  background: var(--green);
}

.action-btn--expense {
  background: var(--coral);
}

.form-title {
  font-size: var(--font-md);
  font-weight: 700;
  margin-bottom: var(--space-sm);
}

.amount-input {
  background: var(--cream);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-md);
  margin-bottom: var(--space-sm);
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.chip {
  background: var(--cream);
  border: 3rpx solid transparent;
  border-radius: var(--radius-full);
  padding: var(--space-xs) var(--space-md);
  font-size: var(--font-sm);
}

.chip.is-selected {
  border-color: var(--coral);
  background: var(--coral-soft);
}

.submit-btn {
  width: 100%;
}

.ledger-title {
  font-size: var(--font-md);
  font-weight: 700;
  margin-bottom: var(--space-sm);
}

.empty {
  font-size: var(--font-sm);
  color: var(--ink-mute);
}

.entry-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-sm) 0;
  border-bottom: 2rpx dashed var(--cream-deep);
}

.entry-item:last-of-type {
  border-bottom: none;
}

.entry-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.entry-emoji {
  font-size: var(--font-xl);
}

.entry-label {
  font-size: var(--font-sm);
  font-weight: 700;
}

.entry-meta {
  font-size: var(--font-xs);
  color: var(--ink-mute);
}

.entry-amount {
  font-size: var(--font-md);
  font-weight: 700;
}

.entry-amount.is-income {
  color: var(--green);
}

.entry-amount.is-expense {
  color: var(--coral);
}

.goal-card {
  margin-bottom: var(--space-md);
}

.goal-name {
  font-size: var(--font-sm);
  font-weight: 700;
  margin-bottom: var(--space-xs);
}

.goal-bar {
  height: 16rpx;
  border-radius: var(--radius-full);
  background: var(--cream-deep);
  overflow: hidden;
}

.goal-fill {
  height: 100%;
  border-radius: var(--radius-full);
  background: var(--green);
}

.goal-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-xs);
  color: var(--ink-soft);
  margin-top: var(--space-xs);
}

.goal-done {
  color: var(--coral);
  font-weight: 700;
}

.goal-add-btn {
  width: 100%;
  margin-top: var(--space-sm);
}

.goal-form {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 2rpx dashed var(--cream-deep);
}
